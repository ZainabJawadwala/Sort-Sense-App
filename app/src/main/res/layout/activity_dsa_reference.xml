<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DSA Reference Guide"
            android:textColor="@color/action_bar"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- SORTING SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I. Sorting Algorithms"
            android:textColor="@color/action_bar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Bubble Sort -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Bubble Sort" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(n), θ(n²), O(n²) | Space: O(1)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram:\n[5|1|4|2] -> (Compare 5,1)\n[1|5|4|2] -> (Swap 5,1)\n[1|4|5|2] -> (Swap 5,4)\n[1|4|2|5] -> (5 BUBBLED)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Selection Sort -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. Selection Sort" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(n²), θ(n²), O(n²) | Space: O(1)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram:\n[5|1|4|2] -> (Min is 1)\n[1|5|4|2] -> (Swap 5,1)\n[1|2|4|5] -> (Min is 2, Swap 5,2)\n[Sorted | Unsorted]" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Insertion Sort -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3. Insertion Sort" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(n), θ(n²), O(n²) | Space: O(1)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram:\n[5] | 1,4,2 -> (Pick 1)\n[1,5] | 4,2 -> (Insert 1 before 5)\n[1,4,5] | 2 -> (Insert 4 before 5)\n[1,2,4,5] |  -> (Sorted)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick Sort -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4. Quick Sort" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(n log n), θ(n log n), O(n²) | Space: O(log n)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram:\n   [Pivot: 4]\n    /      \\\n [1, 2]   [5]\n (Recurse) (Done)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Merge Sort -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5. Merge Sort" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(n log n), θ(n log n), O(n log n) | Space: O(n)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram:\n [5,1] [4,2]  (Split)\n [1,5] [2,4]  (Sort)\n [1,2,4,5]    (Merge)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SEARCHING SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="II. Searching Algorithms"
            android:textColor="@color/action_bar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Linear Search -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Linear Search" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(1), θ(n), O(n) | Space: O(1)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram (Find 4):\n[5] [1] [4] [2]\n 1.  2.  3.(FOUND!)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Binary Search -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2. Binary Search" android:textStyle="bold" android:textColor="#3F51B5" android:textSize="16sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time: Ω(1), θ(log n), O(log n) | Space: O(1)" android:textSize="13sp" android:layout_marginTop="4dp" android:textColor="@color/black" android:textStyle="bold"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Diagram (Find 5):\n[1, 2, 4, 5, 9]\n L    M     H (Target > 4)\n       L M  H (FOUND!)" android:textSize="12sp" android:fontFamily="monospace" android:background="#EEEEEE" android:padding="12dp" android:layout_marginTop="8dp" android:textColor="@color/black"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
